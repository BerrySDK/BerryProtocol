                          }
                },
    "publishConfig":  {
                          "access":  "public"
                      },
    "dependencies":  {
                         "@berrysdk/auth":  "0.1.1",
                         "@berrysdk/events":  "0.1.1",
                         "@berrysdk/media":  "0.1.1",
                         "@berrysdk/messages":  "0.1.1",
                         "@berrysdk/socket":  "0.1.3",
                         "@berrysdk/store":  "0.1.1",
                         "pino":  "^9.6.0",
                         "qrcode-terminal":  "^0.12.0"
                     }
}
